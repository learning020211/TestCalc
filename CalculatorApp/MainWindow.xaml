<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculatorApp"
        mc:Ignorable="d"
        Title="Calculator" Height="600" Width="400" Background="#1C1C1C" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <!-- Base Button Style -->
        <Style x:Key="CalcButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="40" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Number Button Style -->
        <Style x:Key="NumberButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonStyle}">
            <Setter Property="Background" Value="#505050"/>
        </Style>

        <!-- Operator Button Style -->
        <Style x:Key="OperatorButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonStyle}">
            <Setter Property="Background" Value="#FF9500"/>
        </Style>

        <!-- Function Button Style -->
        <Style x:Key="FunctionButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonStyle}">
            <Setter Property="Background" Value="#D4D4D2"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Display -->
        <TextBlock x:Name="Display" Grid.Row="0" Grid.ColumnSpan="4" Text="0"
                   Foreground="White" FontSize="80" TextAlignment="Right"
                   VerticalAlignment="Bottom" Margin="10,0,10,10"
                   TextWrapping="NoWrap"/>

        <!-- Row 1 -->
        <Button Content="AC" Grid.Row="1" Grid.Column="0" Style="{StaticResource FunctionButtonStyle}" Click="Function_Click"/>
        <Button Content="+/-" Grid.Row="1" Grid.Column="1" Style="{StaticResource FunctionButtonStyle}" Click="Function_Click"/>
        <Button Content="%" Grid.Row="1" Grid.Column="2" Style="{StaticResource FunctionButtonStyle}" Click="Function_Click"/>
        <Button Content="÷" Grid.Row="1" Grid.Column="3" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

        <!-- Row 2 -->
        <Button Content="7" Grid.Row="2" Grid.Column="0" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="8" Grid.Row="2" Grid.Column="1" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="9" Grid.Row="2" Grid.Column="2" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="×" Grid.Row="2" Grid.Column="3" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

        <!-- Row 3 -->
        <Button Content="4" Grid.Row="3" Grid.Column="0" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="5" Grid.Row="3" Grid.Column="1" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="6" Grid.Row="3" Grid.Column="2" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="-" Grid.Row="3" Grid.Column="3" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

        <!-- Row 4 -->
        <Button Content="1" Grid.Row="4" Grid.Column="0" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="2" Grid.Row="4" Grid.Column="1" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="3" Grid.Row="4" Grid.Column="2" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="+" Grid.Row="4" Grid.Column="3" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

        <!-- Row 5 -->
        <Button Content="0" Grid.Row="5" Grid.ColumnSpan="2" Style="{StaticResource NumberButtonStyle}" Click="Number_Click" HorizontalContentAlignment="Left" Padding="35,0,0,0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" CornerRadius="40" Background="{TemplateBinding Background}" Margin="5">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="35,0,0,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Content="." Grid.Row="5" Grid.Column="2" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
        <Button Content="=" Grid.Row="5" Grid.Column="3" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

    </Grid>
</Window>
